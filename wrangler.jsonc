{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "personal-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-01-07",
  "observability": {
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "invocation_logs": true,
      "persist": false
    }
  }
}
